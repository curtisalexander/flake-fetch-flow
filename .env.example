# Copy to .env and fill in, or export these in your shell profile.
# Every Snowflake script and MCP server in this repo auto-loads the repo-root
# .env (variables already exported in your shell take precedence) — no
# credentials ever live in code.

# Account identifier, preferred form: <orgname>-<account_name>  (no .snowflakecomputing.com)
SNOWFLAKE_ACCOUNT=myorg-myaccount

# The Snowflake user the key pair is registered to
SNOWFLAKE_USER=MY_USER

# Your PKCS#8 private key — the CONTENTS of rsa_key.p8, not a path to it.
# (See the README for how to generate the key pair and fill this in with one
# command.) Paste the whole PEM including the BEGIN/END lines; a multi-line
# value works as long as it's wrapped in double quotes, like so:
SNOWFLAKE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
MIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC...   (your key here)
-----END PRIVATE KEY-----"
# A single-line value with literal \n between the PEM lines also works.
# Encrypted keys (BEGIN ENCRYPTED PRIVATE KEY) work too — set the passphrase:
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=...

# Session context (optional but recommended)
SNOWFLAKE_WAREHOUSE=MY_WH
SNOWFLAKE_DATABASE=MY_DB
SNOWFLAKE_SCHEMA=PUBLIC
# Use a READ-ONLY role for anything an agent can drive
SNOWFLAKE_ROLE=ANALYST_RO

# Where the to-file patterns write results (defaults to ./results in this repo)
# FFF_RESULTS_DIR=/somewhere/else
